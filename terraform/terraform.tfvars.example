# =============================================================================
# Joby – Terraform Variables
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
#
# IMPORTANT: Never commit terraform.tfvars to version control.
# =============================================================================

# -- General ------------------------------------------------------------------

aws_region   = "us-east-1"
project_name = "joby"
environment  = "dev"

# -- EC2 ---------------------------------------------------------------------

# Create a key pair in the AWS Console → EC2 → Key Pairs, download the .pem
# file, then enter the key pair name here. Keep the .pem file safe.
key_pair_name = "joby-key"

# Your public IP for SSH access. Find it at https://checkip.amazonaws.com
# Use /32 to restrict to a single IP. Leave empty [] to disable SSH entirely.
allowed_ssh_cidrs = ["203.0.113.5/32"]

# t2.micro and t3.micro are both free-tier eligible (750 hrs/month for 12 months)
ec2_instance_type = "t3.micro"
ec2_volume_size   = 20

# Set to true if you want a static IP that survives instance stop/start.
# Note: an Elastic IP is free only while associated with a running instance.
enable_elastic_ip = false

# -- RDS (PostgreSQL) --------------------------------------------------------

db_name     = "joby"
db_username = "joby_admin"

# At least 12 characters. Use a strong, unique password.
# You can generate one with: openssl rand -base64 18
db_password = "CHANGE_ME_use_a_strong_password_here"

# db.t3.micro is free-tier eligible (750 hrs/month for 12 months, 20 GB storage)
db_instance_class  = "db.t3.micro"
db_allocated_storage = 20

# Dev/learning: true. Production: false (keeps a final snapshot on destroy).
db_skip_final_snapshot = true
db_deletion_protection = false
db_backup_retention_period = 1

# -- S3 ----------------------------------------------------------------------

# Leave empty to auto-generate a unique bucket name.
# If you set this, the name must be globally unique across all AWS accounts.
s3_bucket_name = ""

# Enable if you want to keep old versions of uploaded files.
s3_versioning_enabled = false
