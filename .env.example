## Docker compose / local dev environment variables
## Copy to .env and replace values:
##   cp .env.example .env

# Postgres (Compose service `postgres`)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_DEV
POSTGRES_DB=joby

# Backend (.NET)
ASPNETCORE_ENVIRONMENT=Development
# Docker backend: Host=postgres and Password= must match POSTGRES_PASSWORD above.
# Host-only (dotnet run / psql): use Host=localhost;Port=5300;... with the same password.
ConnectionStrings__DefaultConnection=Host=postgres;Database=joby;Username=postgres;Password=CHANGE_ME_LOCAL_DEV

# If you change POSTGRES_PASSWORD after Postgres has already initialized, remove the old data volume or auth keeps the old password:
#   docker compose --profile local down -v

Jwt__Secret=CHANGE_ME_LOCAL_DEV_AT_LEAST_32_CHARS
Jwt__Issuer=Joby
Jwt__Audience=JobyApp
Jwt__AccessTokenExpirationMinutes=60
Jwt__RefreshTokenExpirationDays=7

# Email verification during registration
Auth__EmailVerificationCodeExpirationMinutes=10
Auth__EmailVerificationResendCooldownSeconds=60

# Global aggregate rate limit
GlobalRateLimit__MaxRequestsPer10Minutes=100
GlobalRateLimit__MaxRequestsPerHour=1000

# CORS allowed origins (optional)
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://localhost:3000
Cors__AllowedOrigins__2=http://localhost:8080

# Reminder emails (optional). Leave Email__Smtp__Host empty to skip sending.
Email__FromAddress=
Email__FromName=Joby
Email__Smtp__Host=
Email__Smtp__Port=587
Email__Smtp__User=
Email__Smtp__Password=
Email__Smtp__UseSsl=true

